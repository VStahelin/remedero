# Signing credentials for release APK
# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.
KEYSTORE_STORE_FILE=app/remedero-release.keystore
KEYSTORE_STORE_PASSWORD=your-store-password
KEYSTORE_KEY_ALIAS=remedero-release
KEYSTORE_KEY_PASSWORD=your-key-password

# IMPORTANTE: o arquivo .keystore referenciado em KEYSTORE_STORE_FILE
# tambem precisa ser guardado em local seguro (ex: Google Drive).
# Sem esse arquivo, as credenciais acima sao inuteis e voce nao consegue
# atualizar o app sem desinstalar (o que apaga todos os dados).

# Caminho do Android SDK na sua maquina.
# Default no Makefile ja aponta para o caminho padrao do Windows.
# So adicione aqui se o seu SDK estiver em outro lugar.
# ANDROID_SDK=C:/Users/SeuUsuario/AppData/Local/Android/Sdk
